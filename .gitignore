# Runtime debug logs (modules/debug_console writes them next to the exe /
# project root at every launch)
debug.log
debug.prev.log

# User-imported custom object detectors ("Import model…" in the Advanced tab
# copies them here). Weights are large and belong to the user, not the repo.
models/custom/

# User-imported custom ACTION models ("Import model…" in the Advanced tab writes
# these fixed root slots). Large weights + the user's own label taxonomy — the
# user's data, never the repo's.
/action_classifier_3d.xml
/action_classifier_3d.bin
/intel_finetuned_classifier_3d_mapping.json
/r3d_finetuned.pth
/r3d_finetuned_mapping.json

# CLIP OpenVINO IR (~600 MB, generated by tools/export_clip_ov.py; CI regenerates
# it before packaging). Without it the app re-converts the model from PyTorch on
# every launch — slow, but never something to commit.
models/clip-vit-base-patch32-ov/

__pycache__/
